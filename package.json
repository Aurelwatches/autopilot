{
  "name": "autopilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite,bot -c cyan,magenta,yellow \"node --env-file=.env server.js\" \"vite\" \"node --env-file=.env bot.js\"",
    "server": "node --env-file=.env server.js",
    "bot": "node --env-file=.env bot.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "start:bot": "node bot.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@supabase/supabase-js": "^2.107.0",
    "discord.js": "^14.26.4",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "vite": "^5.4.0"
  }
}
