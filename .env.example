# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these at: app.supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (not exposed to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Groq ────────────────────────────────────────────────────────────────────
# Get yours at https://console.groq.com/
VITE_GROQ_API_KEY=gsk_...

# ─── Discord ─────────────────────────────────────────────────────────────────
# Webhook URL: Server Settings > Integrations > Webhooks
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CHANNEL_ID=your-channel-id

# ─── API server ──────────────────────────────────────────────────────────────
# After deploying server.js to Railway/Render, set this to your server's public URL
# e.g. https://autopilot-api.up.railway.app
VITE_WEBHOOK_URL=https://your-api-server.up.railway.app/api/webhook
VITE_REPLY_WEBHOOK_URL=https://your-api-server.up.railway.app/api/reply

# Used by bot.js to reach the API server
API_URL=https://your-api-server.up.railway.app

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Find keys at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Recurring Price IDs (Products > Pricing) — one per plan + billing interval
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxx
STRIPE_PRICE_GROWTH_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# ─── App meta ────────────────────────────────────────────────────────────────
VITE_APP_NAME=AutoPilot
VITE_CONTACT_EMAIL=hello@autopilot.ai
VITE_PRIVACY_EMAIL=privacy@autopilot.ai
VITE_SUPPORT_EMAIL=support@autopilot.ai
VITE_WAITLIST_MAX_SUBMISSIONS=3
